{
  "env": {
    "node": true,
    "es2021": true,
    "mocha": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:mocha/recommended"
  ],
  "plugins": ["mocha"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "globals": {
    "browser": "readonly",
    "driver": "readonly",
    "$": "readonly",
    "$$": "readonly",
    "expect": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "mocha/no-mocha-arrows": "off",
    "mocha/no-setup-in-describe": "off"
  }
}
